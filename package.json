{
  "name": "koji-coffee",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "packageManager": "bun@1.2.19",
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && bun run scripts/prerender-routes.ts",
    "build:dev": "vite build --mode development && bun run scripts/prerender-routes.ts",
    "preview": "vite preview --port 8080",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check:pins": "bun run scripts/check-pinned-versions.ts",
    "audit:high": "bun audit --audit-level=high"
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "5.2.8",
    "@fontsource-variable/space-grotesk": "5.2.10",
    "@tailwindcss/vite": "4.2.1",
    "clsx": "2.1.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-router-dom": "7.18.1",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.1",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "9.32.0",
    "@types/node": "26.1.0",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "@vitejs/plugin-react": "5.2.0",
    "eslint": "9.32.0",
    "eslint-config-prettier": "10.1.1",
    "eslint-plugin-prettier": "5.2.6",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "globals": "15.15.0",
    "prettier": "3.7.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.56.1",
    "vite": "8.0.16"
  }
}
